{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "UNLICENSED",
    "require": {
        "php": "^8.4",
        "ext-xml": "*",
        "ext-zip": "*",
        "blade-ui-kit/blade-heroicons": "^2.7",
        "doctrine/dbal": "^4.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.45",
        "laravel/tinker": "^2.10",
        "livewire/livewire": "^3.6.4",
        "livewire/volt": "^1.7.0",
        "predis/predis": "^3.4",
        "shopify/shopify-api": "^6.0",
        "spatie/laravel-activitylog": "^4.12",
        "squizlabs/php_codesniffer": "^3.10",
        "symfony/http-client": "^8.0",
        "symfony/mailgun-mailer": "^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.3",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "laravel/telescope": "^5.18",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\Helpers\\": "Helpers/",
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "php artisan serve"
        ],
        "lint": "./vendor/bin/phpcs --standard=PSR12 app routes"
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
        "ignore": [
            "PKSA-y2cr-5h3j-g3ys",
            "PKSA-2kqm-ps5x-s4f5"
        ]
    }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
